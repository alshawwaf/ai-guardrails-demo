# AI Guardrails Configuration
LAKERA_API_KEY=your_guardrails_api_key
LAKERA_PROJECT_ID=your_project_id
LAKERA_API_URL=https://api.lakera.ai/v2/guard

# OpenAI Configuration (Optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Azure OpenAI Configuration (Optional)
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_ENDPOINT=your_azure_endpoint
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-2024-07-18

# Azure AI Content Safety Configuration (Optional)
AZURE_CONTENT_SAFETY_KEY=your_azure_cs_key
AZURE_CONTENT_SAFETY_ENDPOINT=your_azure_cs_endpoint

# Google Gemini Configuration (Optional)
GEMINI_API_KEY=your_gemini_api_key

# Ollama Configuration (Optional)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
# Default local model for the "target LLM" in scans. An uncensored model is
# intentional here — it complies with jailbreaks when Guard is off, which is
# what makes Guard's block visible. The settings DB overrides this if set.
OLLAMA_MODEL=richardyoung/mythos-9b-unhinged-abliterated:latest

# Playground default LLM — what the UI opens with when the browser has no saved
# choice (a user's own selection still wins). Set provider=ollama so the demo
# works out of the box against a local model.
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=richardyoung/mythos-9b-unhinged-abliterated:latest

# Application Configuration
APP_PORT=9000
LOGS_DIR=logs
LOG_FILENAME=application.log

# CORS Configuration
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=*

# Rate Limiting Configuration
RATE_LIMIT_DAILY=200
RATE_LIMIT_HOURLY=50
# For production with Redis: redis://localhost:6379
RATE_LIMIT_STORAGE=memory://

# Production Server Configuration (Gunicorn)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:9000

# Security Configuration
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_please
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
